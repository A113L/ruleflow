    def _toggle_theme(self):
        old = THEME.current
        new = LIGHT_THEME if old.name == "dark" else DARK_THEME
        color_map = _theme_color_map(old, new)
        THEME.set(new)

        # Re-theme every existing widget in the tree.
        _retheme_tree(self, color_map)
        self._configure_ttk_styles()

        # The log panel's text background isn't part of the shared palette
        # (it is intentionally darker/lighter than the surrounding chrome).
        if self._log.cget("bg") == old.log_bg:
            self._log.config(bg=new.log_bg)

        # Text-widget tags aren't tk options, so they need an explicit refresh.
        for name in ("accent", "success", "warning", "danger", "info"):
            self._log.tag_config(name, foreground=getattr(new, name))
        self._log.tag_config("muted", foreground=new.fg2)
        self._log.tag_config("search_hit", background=new.info, foreground="#0a0a0a")

        # Raw ANSI-coloured tool output already rendered in the log uses
        # per-colour tags (col_<hex>) tied to the old palette — remap those
        # too, or previously-printed lines stay hard to read on the new bg.
        old_ansi = ANSI_COLOURS_LIGHT if old.name == "light" else ANSI_COLOURS_DARK
        new_ansi = ANSI_COLOURS_LIGHT if new.name == "light" else ANSI_COLOURS_DARK
        ansi_map = {old_ansi[k]: new_ansi[k] for k in old_ansi}
        for tag in list(getattr(self, "_colour_tags", ())):
            try:
                cur_fg = self._log.tag_cget(tag, "foreground")
            except Exception:
                continue
            if cur_fg in ansi_map:
                self._log.tag_config(tag, foreground=ansi_map[cur_fg])

        # Mode cards compute their colours fresh from THEME each call.
        if hasattr(self, "_mode_cards"):
            self._set_mode(self._mode_var.get())

        self._theme_btn.config(
            text="🌙  Dark mode" if new.name == "light" else "☀  Light mode"
        )

