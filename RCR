    # ── Device Scanning ─────────────────────────────────────────────

    def _scan_devices(self):
        self._dev_status.config(text="Scanning…", fg=THEME.warning)
        self._log_system("Scanning for OpenCL devices…")
        threading.Thread(target=self._scan_thread, daemon=True).start()

    def _scan_thread(self):
        py = sys.executable
        rulest_py = os.path.join(SCRIPT_DIR, "rulest_v2.py")
        try:
            result = subprocess.run([py, rulest_py, "--list-devices"], capture_output=True, text=True, timeout=30)
            raw = result.stdout + result.stderr
        except Exception as e:
            self.after(0, lambda: self._scan_failed(str(e)))
            return
        clean = strip_ansi(raw)
        devices = [("auto", "Auto-detect (recommended)")]
        for line in clean.splitlines():
            m = re.search(r'\[?\b(\d+)\]?\s*[:\-]?\s*(.+)', line)
            if m and any(k in line.lower() for k in ["nvidia", "amd", "intel", "gpu", "geforce", "radeon"]):
                dev_id = m.group(1)
                desc = m.group(2).strip()
                devices.append((dev_id, f"[{dev_id}] {desc}"))
        self.after(0, lambda: self._scan_complete(devices, raw))

    def _scan_failed(self, error: str):
        self._dev_status.config(text=f"Scan failed: {error}", fg=THEME.danger)
        self._log_error(f"Device scan failed: {error}")

    def _scan_complete(self, devices: List[Tuple[str, str]], raw: str):
        self._devices = devices
        self._dev_combo["values"] = [d[1] for d in devices]
        self._dev_combo.set(devices[0][1])
        count = len(devices) - 1
        if count > 0:
            self._dev_status.config(text=f"Found {count} device(s). Auto-detect recommended.", fg=THEME.success)
        else:
            self._dev_status.config(text="No OpenCL devices found. CPU fallback will be used.", fg=THEME.warning)
        self._log_system(f"Device scan complete. {count} device(s) found.")
        self._log_muted(strip_ansi(raw))

    # ── Log Writing ─────────────────────────────────────────────────

    def _log_system(self, text: str):
        line = f"[{time.strftime('%H:%M:%S')}] {text}\n"
        self._write_to_disk_and_tail(line)
        self._log_queue.put(("system", line))

    def _log_error(self, text: str):
        line = f"[{time.strftime('%H:%M:%S')}] ERROR: {text}\n"
        self._write_to_disk_and_tail(line)
        self._log_queue.put(("error", line))

    def _log_muted(self, text: str):
        line = text + "\n"
        self._write_to_disk_and_tail(line)
        self._log_queue.put(("muted", line))

    def _log_line(self, text: str):
        line = text + "\n"
        self._write_to_disk_and_tail(line)
        self._log_queue.put(("ansi_line", line))

    def _clear_log(self):
        self._log.config(state="normal")
        self._log.delete("1.0", "end")
        self._log.config(state="disabled")
        self._log_line_count = 0

    def _open_log_stream(self):
        os.makedirs(self._outdir_var.get(), exist_ok=True)
        ts = time.strftime("%Y%m%d_%H%M%S")
        self._log_file_path = os.path.join(self._outdir_var.get(), f"rcr_run_{ts}.log")
        try:
            with self._log_file_lock:
                self._log_file = open(self._log_file_path, "a", encoding="utf-8", errors="replace")
        except Exception as e:
            self._log_file = None
            self._log_error(f"Could not open log file for writing: {e}")

    def _close_log_stream(self):
        with self._log_file_lock:
            if self._log_file:
                try:
                    self._log_file.close()
                except Exception:
                    pass
                self._log_file = None

    def _write_to_disk_and_tail(self, text: str):
        """Called immediately when a log message is produced (may be from a
        background thread), so the on-disk log and the OOM-detection tail are
        always complete — independent of how fast the GUI thread can drain
        the display queue. This guarantees no log lines are ever lost."""
        with self._log_file_lock:
            if self._log_file:
                try:
                    self._log_file.write(strip_ansi(text))
                except Exception:
                    pass
        self._recent_tail.append(text)
        if len(self._recent_tail) > 200:
            self._recent_tail = self._recent_tail[-200:]

    # ── Main Polling Loop ───────────────────────────────────────────

    def _start_polling(self):
        self.after(50, self._poll_loop)
        self.after(2000, self._update_memory)

    def _poll_loop(self):
        processed = 0
        while processed < 200:
            try:
                kind, content = self._log_queue.get_nowait()
            except queue.Empty:
                break
            self._apply_log_entry(kind, content)
            processed += 1

        dropped = self._log_queue.clear_dropped()
        if dropped > 0:
            self._apply_log_entry("system", f"[{time.strftime('%H:%M:%S')}] … {dropped} log lines dropped (backpressure)\n")

        self.after(50, self._poll_loop)

    def _apply_log_entry(self, kind: str, content: str):
        self._log.config(state="normal")

        if kind in ("ansi_line", "system", "error", "muted"):
            tag = {"system": "info", "error": "danger", "muted": "muted"}.get(kind)
            if kind == "ansi_line":
                for chunk, colour in parse_ansi_segments(content):
                    if not chunk:
                        continue
                    if colour:
                        t = f"col_{colour.replace('#', '')}"
                        if t not in self._colour_tags:
                            self._log.tag_config(t, foreground=colour)
                            self._colour_tags.add(t)
                        self._log.insert("end", chunk, t)
                    else:
                        self._log.insert("end", chunk)
            else:
                self._log.insert("end", content, tag)
            self._log_line_count += content.count("\n")

        else:
            self._log.insert("end", content)
            self._log_line_count += content.count("\n")

        if self._autoscroll:
            self._log.see("end")
        self._log.config(state="disabled")

    def _update_memory(self):
        if self._running:
            mem_str = self._mem_monitor.format()
            self._mem_label.config(text=f"RAM: {mem_str}")
            if self._mem_monitor.is_under_pressure():
                self._mem_label.config(fg=THEME.warning)
            else:
                self._mem_label.config(fg=THEME.fg2)
        self.after(2000, self._update_memory)

    # ── Concentrator Post-Processing Filters ─────────────────────────
    #
    # v0.6: The Step-3b filters (1-5) used to be reimplemented here in
    # Python, separately from concentrator.py's own logic — which is why
    # they didn't actually reflect what concentrator does (different
    # occurrence counting, a stripped-down functional-redundancy check,
    # etc). They are now passed straight through to concentrator.py's own
    # --filter-min-occ / --filter-max-rules / --filter-func-redundancy /
    # --filter-inverse / --filter-hashcat-cleanup CLI flags (see
    # _concentrator_filter_args() and the Stage 2 block in
    # _pipeline_thread), so RCR always uses concentrator's real, single
    # source of truth for these filters. Each flag is independent — only
    # the ones the user checked are passed — and concentrator applies
    # them in the fixed order 1→5 in a single pass so occurrence counts
    # stay consistent from one filter to the next.

    def _concentrator_filter_args(self) -> List[str]:
        """Build the --filter-* CLI args for concentrator.py from whichever
        Step-3b checkboxes are enabled. Only enabled options are included,
        so each of the 5 filters is executed independently."""
        conc_args: List[str] = []
        if self._conc_min_occ_var.get():
            conc_args += ["--filter-min-occ", self._conc_min_occ_val.get()]
        if self._conc_max_rules_var.get():
            conc_args += ["--filter-max-rules", self._conc_max_rules_val.get()]
        if self._conc_func_red_var.get():
            conc_args += ["--filter-func-redundancy", "--yes"]
        if self._conc_inv_var.get():
            conc_args += ["--filter-inverse", self._conc_inv_val.get()]
        if self._conc_hashcat_var.get():
            conc_args += ["--filter-hashcat-cleanup", self._conc_hashcat_mode.get()]
        return conc_args

    # ── Pipeline Execution ────────────────────────────────────────

    def _validate(self) -> bool:
        # Check that at least one stage is selected
        if not any([self._run_rulest.get(), self._run_conc.get(), self._run_ranker.get()]):
            messagebox.showerror("No Stage Selected", "Please select at least one stage to run.")
            return False

        # If rulest is not selected but concentrator or ranker is, require external rules file
        if not self._run_rulest.get() and (self._run_conc.get() or self._run_ranker.get()):
            rules_path = self._rules_file_picker.get()
            if not rules_path:
                messagebox.showerror("Missing Rules File", "When skipping rulest, an external rules file is required. Please select one in the 'External Rules Input' section.")
                return False
            if not os.path.isfile(rules_path):
                messagebox.showerror("File Not Found", f"Rules file not found:\n{rules_path}")
                return False

        # If rulest is selected, require base + target wordlists
        if self._run_rulest.get():
            for label, path in [
                ("Base wordlist", self._base_wl.get()),
                ("Target wordlist", self._tgt_wl.get()),
            ]:
                if not path:
                    messagebox.showerror("Missing Input", f"{label} is required when running rulest.")
                    return False
                if not os.path.isfile(path):
                    messagebox.showerror("File Not Found", f"{label}: {path} — File does not exist.")
                    return False

        # If ranker is selected, require cracked passwords and base wordlist
        if self._run_ranker.get():
            for label, path in [
                ("Base wordlist", self._base_wl.get()),
                ("Cracked passwords", self._cracked.get()),
            ]:
                if not path:
                    messagebox.showerror("Missing Input", f"{label} is required when running ranker.")
                    return False
                if not os.path.isfile(path):
                    messagebox.showerror("File Not Found", f"{label}: {path} — File does not exist.")
                    return False

        return True

    def _run(self):
        if self._running or not self._validate():
            return
        self._running = True
        self._cancel_event.clear()
        self._stage = 0
        self._recent_tail = []
        self._run_btn.config(state="disabled")
        self._stop_btn.config(state="normal")
        self._open_log_stream()
        self._log_system(f"Pipeline starting… (full log: {self._log_file_path})")
        self._set_status("Running…", THEME.accent)
        threading.Thread(target=self._pipeline_thread, daemon=True).start()

    def _stop(self):
        if not self._running:
            return
        self._cancel_event.set()
        self._log_system("Stop requested, terminating current process…")
        if self._process:
            self._process.terminate()
            self._process = None
        self._mem_monitor.set_child_pid(None)
        self._finish(aborted=True)

    def _finish(self, aborted: bool = False, error: bool = False):
        if not self._running:
            return
        self._running = False
        self._close_log_stream()
        gc.collect()
        self._run_btn.config(state="normal")
        self._stop_btn.config(state="disabled")
        if aborted:
            self._set_stage(-1)
            self._set_status("Stopped", THEME.warning)
            self._log_system("Pipeline stopped by user.")
        elif error:
            self._set_stage(-1)
            self._set_status("Failed", THEME.danger)
        else:
            self._set_stage(10)
            self._set_status("Complete ✓", THEME.success)
            self._log_system("Pipeline finished successfully.")

    def _set_stage(self, stage: int):
        for i, dot in enumerate(self._stage_dots, 1):
            if stage == -1:
                dot.config(bg=THEME.danger if i == self._stage else THEME.surface,
                           fg="#0a0a0a" if i == self._stage else THEME.fg2)
            elif stage == 10:
                dot.config(bg=THEME.success, fg="#0a0a0a")
            elif i < stage:
                dot.config(bg=THEME.success, fg="#0a0a0a")
            elif i == stage:
                dot.config(bg=THEME.accent, fg="#0a0a0a")
            else:
                dot.config(bg=THEME.surface, fg=THEME.fg2)

    def _device_args(self) -> List[str]:
        dev_display = self._dev_var.get()
        if not dev_display or dev_display.lower().startswith("auto"):
            return []
        m = re.search(r'\[(\d+)\]', dev_display)
        if m:
            return ["--device", m.group(1)]
        if dev_display.isdigit():
            return ["--device", dev_display]
        return ["--device", dev_display]

    def _check_for_oom(self) -> bool:
        tail = "\n".join(self._recent_tail[-100:])
        return bool(OOM_PATTERNS.search(tail))

    def _format_cmd_for_display(self, cmd: List[str]) -> str:
        """Return a platform-appropriate shell-safe string for the log."""
        if sys.platform == "win32":
            # subprocess.list2cmdline produces the exact string Windows
            # CreateProcess would receive — perfect for display.
            return subprocess.list2cmdline(str(a) for a in cmd)
        return " ".join(shlex.quote(str(a)) for a in cmd)

    def _run_step(self, cmd: List[str], label: str) -> int:
        self._log_system(f"{'─' * 50}")
        self._log_system(f"Stage: {label}")
        self._log_system(f"{'─' * 50}")
        self._log_muted(f"$ {self._format_cmd_for_display(cmd)}")

        self._process = ManagedProcess()
        env = os.environ.copy()
        env["PYTHONUNBUFFERED"] = "1"
        # When stdout is piped (no real TTY), progress-bar libraries like
        # tqdm can't detect a terminal width and fall back to a narrow
        # default, truncating things like the GA/minimizer speed readout.
        # Giving them an explicit, generous width avoids that.
        env["COLUMNS"] = "250"
        env["LINES"] = "50"

        if not self._process.start(cmd, self._outdir_var.get(), env):
            self._log_error("Failed to start process")
            return -1

        self._mem_monitor.set_child_pid(self._process.pid)

        proc = self._process
        for kind, text in proc.iter_events(timeout=0.3):
            if self._cancel_event.is_set():
                self._log_system("Cancellation detected, stopping…")
                break
            if not text:
                continue

            clean_text = normalize_progress_bars(text.rstrip('\r'))
            self._log_line(clean_text)

        rc = proc.returncode if proc is not None else -1
        self._process = None
        self._mem_monitor.set_child_pid(None)
        gc.collect()

        if rc not in (0, None) and not self._cancel_event.is_set() and self._check_for_oom():
            self._log_error(
                "This looks like an out-of-memory failure (allocation error / process killed).")
            self._log_system("Suggestion: switch the Memory Preset to Low and reduce K / genetic "
                              "population / MAB trials on the Advanced tab, then re-run.")
            self.after(0, self._offer_low_memory_dialog)

        return rc if rc is not None else -1

    def _stage_succeeded(self, rc: int, expected_path: Optional[str], label: str) -> bool:
        """A non-zero exit code is the primary failure signal, but some of
        these tools can exit non-zero from a benign cleanup issue *after*
        writing valid output. If the expected output file was actually
        written (and isn't empty), treat the stage as successful instead of
        failing the whole pipeline over a false alarm."""
        if rc == 0:
            return True
        if expected_path and os.path.isfile(expected_path) and os.path.getsize(expected_path) > 0:
            self._log_system(
                f"{label} exited with code {rc}, but its output file was written "
                f"successfully ({expected_path}) — continuing as if it succeeded."
            )
            return True
        return False

    def _offer_low_memory_dialog(self):
        if messagebox.askyesno(
            "Possible out-of-memory failure",
            "This stage appears to have failed because it ran out of memory (host RAM or GPU VRAM). Apply the Low-Memory preset now (lower bloom filter size, K, genetic population, and MAB trial counts) so the next run is less likely to hit the same wall?"
        ):
            self._apply_low_memory()

    def _pipeline_thread(self):
        outdir = os.path.normpath(self._outdir_var.get())
        base_wl = os.path.normpath(self._base_wl.get()) if self._base_wl.get() else ""
        tgt_wl = os.path.normpath(self._tgt_wl.get()) if self._tgt_wl.get() else ""
        cracked = os.path.normpath(self._cracked.get()) if self._cracked.get() else ""

        depth = int(self._adv_depth.get())
        gen_gen = int(self._adv_gg.get())
        gen_pop = int(self._adv_gp.get())
        th = float(self._adv_th.get())
        bm = int(self._adv_bm.get())
        s0 = int(self._adv_s0.get())
        tok_p = int(self._adv_tp.get())
        tok_s = int(self._adv_ts.get())
        rk = int(self._adv_rk.get())
        ms = int(self._adv_ms.get())
        mf = int(self._adv_mf.get())
        preset = self._preset_var.get()
        legacy = self._legacy_var.get()

        py = sys.executable
        rulest_py = os.path.join(SCRIPT_DIR, "rulest_v2.py")
        conc_py = os.path.join(SCRIPT_DIR, "concentrator.py")
        rank_py = os.path.join(SCRIPT_DIR, "ranker.py")
        dev_args = self._device_args()

        # ── Stage 1: rulest ─────────────────────────────────────────
        s1 = os.path.join(outdir, "stage1_raw.rule")
        if self._run_rulest.get():
            self.after(0, lambda: self._set_stage(1))
            self.after(0, lambda: self._status_label.config(text="Stage 1/3: rulest…"))

            rc = self._run_step([
                py, rulest_py, base_wl, tgt_wl,
                "-o", s1,
                "--max-depth", str(depth),
                "--token-strip",
                "--genetic",
                "--genetic-generations", str(gen_gen),
                "--genetic-pop", str(gen_pop),
                "--target-hours", str(th),
                "--bloom-mb", str(bm),
                "--token-strip-max-prefix", str(tok_p),
                "--token-strip-max-suffix", str(tok_s),
                "--token-strip-workers", str(s0),
            ] + dev_args, "rulest — rule extraction")

            if self._cancel_event.is_set() or not self._stage_succeeded(rc, s1, "rulest"):
                self.after(0, lambda: self._finish(error=True))
                return

            gc.collect()
            self._log_system("Memory cleanup between stages…")
        else:
            # Use external rules file instead of rulest output
            s1 = os.path.normpath(self._rules_file_picker.get())
            self._log_system(f"Skipping rulest — using external rules: {s1}")

        # ── Stage 2: concentrator ───────────────────────────────────
        s2b = os.path.join(outdir, "stage2_cleaned")
        cleaned = None
        if self._run_conc.get():
            self.after(0, lambda: self._set_stage(2))
            self.after(0, lambda: self._status_label.config(text="Stage 2/3: concentrator…"))

            conc_format = "expanded" if self._concfmt_var.get() else "line"
            filter_args = self._concentrator_filter_args()
            conc_cmd = [
                py, conc_py,
                "-p", s1,
                "--output_base_name", s2b,
                "--output-format", conc_format,
            ] + filter_args

            if filter_args:
                self._log_system(
                    "Step 3b advanced filters enabled — concentrator will run them "
                    "(in order 1→5) as part of this stage."
                )
            rc = self._run_step(conc_cmd, "concentrator — rule optimization + advanced filtering")

            if self._cancel_event.is_set():
                self.after(0, lambda: self._finish(error=True))
                return

            expected = s2b + "_processed.rule"
            matches = [expected] if os.path.isfile(expected) else glob.glob(s2b + "*.rule")
            if not matches:
                fallback = sorted(
                    [f for f in glob.glob(os.path.join(outdir, "*.rule")) if os.path.abspath(f) != os.path.abspath(s1)],
                    key=os.path.getmtime, reverse=True
                )
                if fallback:
                    matches = [fallback[0]]
                    self._log_system(f"Using fallback output: {matches[0]}")
            if not matches:
                extra = f" (process also exited with code {rc})" if rc != 0 else ""
                self._log_error(f"No concentrator output found: {s2b}*.rule{extra}")
                self.after(0, lambda: self._finish(error=True))
                return
            elif rc != 0:
                self._log_system(
                    f"concentrator exited with code {rc}, but its output file was written "
                    f"successfully ({matches[0]}) — continuing as if it succeeded."
                )

            cleaned = matches[0]
            self._log_system(f"Using cleaned rules: {cleaned}")

            gc.collect()
        else:
            # If concentrator is skipped, pass the rules file directly to ranker
            cleaned = s1
            self._log_system(f"Skipping concentrator — passing rules directly to ranker: {cleaned}")

        # ── Stage 3: ranker ─────────────────────────────────────────
        s3 = os.path.join(outdir, "stage3_ranking.csv")
        if self._run_ranker.get():
            self.after(0, lambda: self._set_stage(3))
            self.after(0, lambda: self._status_label.config(text="Stage 3/3: ranker (this may take a while)…"))

            cmd3 = [py, rank_py, "-w", base_wl, "-r", cleaned, "-c", cracked, "-o", s3,
                    "-k", str(rk), "--preset", preset] + dev_args
            if legacy:
                cmd3.append("--legacy")
                self._log_system("Using Legacy (exhaustive) ranker — recommended default, full accuracy.")
            else:
                cmd3 += ["--mab-screening-trials", str(ms), "--mab-final-trials", str(mf)]
                self._log_system("Using MAB (adaptive) ranker — best for very large / imbalanced rule sets.")

            rc = self._run_step(cmd3, "ranker — rule scoring & ranking")
            if self._cancel_event.is_set() or not self._stage_succeeded(rc, s3, "ranker"):
                self.after(0, lambda: self._finish(error=True))
                return
        else:
            self._log_system("Skipping ranker — pipeline complete up to selected stages.")

        self._log_system(f"{'─' * 50}")
        self._log_system("Pipeline complete!")
        if self._run_ranker.get():
            self._log_system(f"Results: {s3}")
        self._log_system(f"{'─' * 50}")
        self.after(0, self._finish)

    # ── Window Management ─────────────────────────────────────────

    def _on_close(self):
        if self._running:
            if messagebox.askyesno("Quit", "Pipeline is running. Stop and quit?"):
                self._stop()
                self.destroy()
        else:
            self._close_log_stream()
            self.destroy()


if __name__ == "__main__":
    app = RCRApp()
    app.mainloop()
